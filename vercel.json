{
  "rewrites": [
    { "source": "/api/banner.svg", "destination": "/api/banner" },
    { "source": "/api/stats.svg", "destination": "/api/stats" },
    { "source": "/api/members.svg", "destination": "/api/members" },
    { "source": "/api/activity.svg", "destination": "/api/activity" },
    { "source": "/api/category/:name.svg", "destination": "/api/category/:name" },
    { "source": "/api/project/:name.svg", "destination": "/api/project/:name" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
